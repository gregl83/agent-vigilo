package vigilo:evaluator@0.1.0;

// data types
interface types {
    record context {
        db: string,
    }
    record input {
        context: context,
    }

    record evaluator-identity {
        namespace: string,
        name: string,
        version: string,
        content-hash: option<string>,
        interface-version: option<string>,
    }

    variant evaluation-dimension {
        correctness,
        format,
        safety,
        quality,
        latency,
        tool-use,
        calibration,
        other(string),
    }

    enum evaluation-status {
        passed,
        failed,
        error,
        skipped,
    }

    enum severity {
        none,
        low,
        medium,
        high,
        critical,
    }

    enum preference-outcome {
        preferred,
        tie,
        not-preferred,
    }

    variant score {
        binary(bool),
        range(tuple<f64, f64, f64>),
        normalized(f64),
        severity-mapped(severity),
        preference(preference-outcome),
        informational,
    }

    record evaluator-finding {
        dimension: evaluation-dimension,
        status: evaluation-status,
        score: score,
        blocking: bool,
        severity: severity,
        failure-category: option<string>,
        reason: option<string>,
        evidence-json: string,
        tags: list<string>,
    }

    record output {
        evaluator: evaluator-identity,
        results: list<evaluator-finding>,
        metadata-json: string,
    }
}

// executor functions exposed to evaluators
interface executor {
    // tracing
    trace: func(msg: string);
    debug: func(msg: string);
    warn: func(msg: string);
    error: func(msg: string);

    // http requests
    record http-header {
        name: string,
        value: string,
    }
    record http-request {
        method: string,
        uri: string,
        headers: list<http-header>,
        body: option<list<u8>>,
        timeout-ms: option<u32>,
    }
    record http-response {
        status: u16,
        headers: list<http-header>,
        body: list<u8>,
    }
    // outbound HTTP (host-mediated, policy-controlled)
    send-http-request: func(req: http-request) -> result<http-response, string>;
}

// evaluator interface
interface evaluator {
    use types.{input, output};
    evaluate: func(input: input) -> result<output, string>;
}

world evaluator-world {
    import types;
    import executor;
    export evaluator;
}
